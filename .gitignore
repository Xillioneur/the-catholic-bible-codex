# Catholic Bible Codex - Future-Proof Git Ignore
# Version 1.1 - 2026 Standards

# --- Dependencies ---
/node_modules
/.pnp
.pnp.js
.pnpm-lock.yaml.bak
.pnpm-debug.log*

# --- Next.js / Turbopack / Webpack ---
/.next/
/out/
/.turbo
/.vercel
next-env.d.ts
*.tsbuildinfo

# --- Serwist / PWA Artifacts ---
# We keep sw.ts (source) but ignore the generated public assets
/public/sw.js
/public/sw.js.map
/public/workbox-*.js
/public/fallback-*.js

# --- Database & Prisma ---
# Ignore the generated Prisma Client as it should be generated in CI/local
/generated/
/prisma/migrations/
/prisma/db.sqlite
/prisma/db.sqlite-journal
db.sqlite

# --- Environment Variables ---
# Absolute mandate: NEVER commit secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.sample
# Allow only .env.example
!.env.example

# --- Testing & Coverage ---
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# --- Operating System ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- IDEs & Editors ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo
.project
.settings/

# --- Misc ---
*.log
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/build
.eslintcache
